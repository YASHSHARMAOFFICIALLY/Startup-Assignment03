# SalesIO OS — Environment Variables
# Copy this file to .env.local and fill in values.

# Database (Neon Postgres — required)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth.js (required)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_RUN_openssl_rand_base64_32

# Google OAuth (optional)
NEXT_PUBLIC_GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auto-sync cron (Vercel sets this automatically for cron jobs)
CRON_SECRET=

# Fallback display name/avatar
NEXT_PUBLIC_USER_NAME=Admin
NEXT_PUBLIC_USER_AVATAR=https://i.pravatar.cc/40?img=11
